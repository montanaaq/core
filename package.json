{
	"name": "frontend-toolkit",
	"version": "0.1.0",
	"description": "CLI for copying frontend toolkit packages and docs into projects.",
	"type": "module",
	"bin": {
		"toolkit": "./dist/index.js"
	},
	"files": [
		"dist",
		"packages",
		"docs"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "chmod +x dist/index.js",
		"prepare": "npm run build",
		"dev": "tsx src/index.ts",
		"start": "node dist/index.js",
		"lint": "biome lint",
		"format": "biome format --write"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"biome format --write",
			"biome lint --fix"
		]
	},
	"dependencies": {
		"commander": "^12.1.0",
		"fs-extra": "^11.2.0",
		"ora": "^8.1.1"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.10.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"engines": {
		"node": ">=20"
	}
}
